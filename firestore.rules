rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // users/{uid} — each user can write their own profile doc freely.
    // A user may ALSO write someone else's doc, but only to claim
    // themselves as that doc's linkedCaregiverId (needed for the
    // invite-redeem flow, where the caregiver updates the patient's doc).
    match /users/{userId} {
      allow read: if request.auth != null &&
        (request.auth.uid == userId ||
         resource.data.linkedCaregiverId == request.auth.uid ||
         resource.data.linkedPatientId == request.auth.uid);

      allow write: if request.auth != null &&
        (request.auth.uid == userId ||
         request.resource.data.linkedCaregiverId == request.auth.uid);
    }

    // invites/{code} — only the creating patient can create their own invite.
    // Any signed-in user can read/redeem an invite by code (needed to look
    // up + claim it), but redemption only flips 'used' from false -> true
    // once, and only the redeemer can set themselves as caregiverId.
    match /invites/{code} {
      allow create: if request.auth != null &&
        request.resource.data.patientId == request.auth.uid &&
        request.resource.data.used == false;

      allow read: if request.auth != null;

      allow update: if request.auth != null &&
        resource.data.used == false &&
        request.resource.data.used == true &&
        request.resource.data.caregiverId == request.auth.uid;

      allow delete: if false;
    }
  }
}
